# Qeet ID marketing site — copy to `.env.local` for local dev (gitignored).
# Next.js inlines NEXT_PUBLIC_* at build; only public values belong here (no secrets).
# The marketing site doesn't call the backend directly — it links to the console.
# Each value below is the local-dev default; the `# prod:` comment is the live value.

# Canonical / OG base URL for this site.
# prod: https://id.qeet.in
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Admin console the Sign in / Sign up links point to.
# prod: https://console.id.qeet.in
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3002
