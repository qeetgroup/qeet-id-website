# Production build-time config for the marketing site (id.qeet.in).
# Next inlines NEXT_PUBLIC_* at build; only public values belong here (no secrets).
# The marketing site doesn't call the backend API directly — it links to the
# dashboard for sign-in/sign-up.

# Canonical/OG base URL for this site.
NEXT_PUBLIC_SITE_URL=https://id.qeet.in

# Dashboard base URL the Sign in / Sign up links point to.
NEXT_PUBLIC_DASHBOARD_URL=https://console.id.qeet.in
